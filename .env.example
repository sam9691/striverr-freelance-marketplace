# This is a template for environment variables
# Copy this file to .env and fill in your actual values

# MongoDB Connection String
# For local: mongodb://localhost:27017/fiverr
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/fiverr
MONGO=mongodb://localhost:27017/fiverr

# JWT Secret Key (use a random string)
JWT_KEY=your_secret_jwt_key_here

# Stripe Secret API Key (get from https://dashboard.stripe.com/apikeys)
STRIPE=sk_test_your_stripe_secret_key_here
